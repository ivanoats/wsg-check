{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/core/*": ["./src/core/*"],
      "@/checks/*": ["./src/checks/*"],
      "@/report/*": ["./src/report/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/config/*": ["./src/config/*"],
      "styled-system/css": ["./styled-system/css"],
      "styled-system/jsx": ["./styled-system/jsx"],
      "styled-system/patterns": ["./styled-system/patterns"],
      "styled-system/recipes": ["./styled-system/recipes"],
      "styled-system/tokens": ["./styled-system/tokens"],
      "styled-system/types": ["./styled-system/types"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "styled-system"]
}
