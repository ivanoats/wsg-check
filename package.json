{
  "name": "wsg-check",
  "version": "0.0.1",
  "description": "Checks a website with the Web Sustainabilty Guidelines",
  "license": "private",
  "author": "van Storck",
  "type": "module",
  "main": "index.js",
  "bin": {
    "wsg-check": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:a11y": "pa11y-ci --config .pa11yci.json",
    "test:lighthouse": "lhci autorun",
    "prepare": "husky && panda codegen"
  },
  "dependencies": {
    "@ark-ui/react": "^5.32.0",
    "@tgwf/co2": "^0.17.0",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "next": "^16.1.6",
    "psl": "^1.15.0",
    "rate-limiter-flexible": "^9.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "robots-parser": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@pandacss/dev": "^1.8.2",
    "@park-ui/panda-preset": "^0.43.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tgwf__co2": "^0.14.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "pa11y-ci": "^4.0.1",
    "prettier": "^3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "@park-ui/panda-preset": {
      "@zag-js/core": "^0.82.2"
    },
    "tmp": "^0.2.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
