# Environment Variables for wsg-check
# Copy this file to .env.local for local development

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=WSG Check

# FMP API
FMP_API_KEY=your_api_key_here

# API Configuration (optional)
# WSG_API_KEY=your_api_key_here
# WSG_API_CORS_ORIGIN=*
# WSG_API_RATE_LIMIT_POINTS=30
# WSG_API_RATE_LIMIT_DURATION_SECONDS=60

# Analysis settings
# MAX_CRAWL_DEPTH=3
# REQUEST_TIMEOUT_MS=30000
